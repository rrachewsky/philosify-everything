# Backend API
VITE_API_URL=https://api-everything.philosify.org

# CDN for static assets (R2 bucket)
VITE_CDN_URL=https://pub-YOUR-BUCKET.r2.dev

# Supabase (Realtime only — all auth goes through backend HttpOnly cookies)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Feature Flags
VITE_ENABLE_GROK_MODEL=true
VITE_ENABLE_CLAUDE_MODEL=true

# Analytics (future)
VITE_GA_TRACKING_ID=

# Environment
VITE_ENV=production
