# ============================================================
# SECURITY HEADERS - Cloudflare Pages
# ============================================================
# Headers are ADDITIVE in Cloudflare Pages (NOT first-match-wins).
# Multiple matching rules are MERGED. Security headers are defined
# ONLY on the /* catch-all to avoid duplication.
#
# Documentation: https://developers.cloudflare.com/pages/platform/headers/
# ============================================================

# Static assets (fingerprinted by Vite) - cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# JS files (non-fingerprinted like sw.js) - revalidate
/*.js
  Cache-Control: public, max-age=0, must-revalidate

# CSS files - revalidate
/*.css
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# HTML files - never cache
/*.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Video files - immutable assets, cache forever
/*.mp4
  Cache-Control: public, max-age=31536000, immutable

# Legal pages - cache briefly
/pp*
  Cache-Control: public, max-age=3600

/tos*
  Cache-Control: public, max-age=3600

# All routes - security headers (applied once, to every response)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://js.stripe.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://unpkg.com https://cdn.jsdelivr.net https://upload.wikimedia.org https://*.supabase.co https://i.scdn.co https://mosaic.scdn.co https://image-cdn-ak.spotifycdn.com https://image-cdn-fa.spotifycdn.com https://covers.openlibrary.org https://m.media-amazon.com https://books.google.com https://image.tmdb.org https://api.philosify.org; frame-src https://open.spotify.com https://js.stripe.com; connect-src 'self' https://*.supabase.co https://api.stripe.com https://api.philosify.org wss://*.supabase.co https://cloudflareinsights.com https://o22381.ingest.us.sentry.io; media-src 'self' blob: https://pub-2485a0b8727445bbb7148e85a0db3edf.r2.dev; object-src 'none'; base-uri 'self'; form-action 'self';
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
